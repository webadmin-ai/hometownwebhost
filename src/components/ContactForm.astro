---
import { siteConfig } from '../config';
---

<form
  id="contact-form"
  class="contact-form"
  novalidate
  action={siteConfig.contactEndpoint}
  data-api-key={siteConfig.contactApiKey}
>
  <div class="form-group">
    <label for="name">Name <span class="required" aria-hidden="true">*</span></label>
    <input
      type="text"
      id="name"
      name="name"
      required
      maxlength="100"
      autocomplete="name"
      aria-required="true"
    />
    <p class="form-error" id="name-error" role="alert" aria-live="polite"></p>
  </div>

  <div class="form-group">
    <label for="has-existing-website">Do you have an existing website?</label>
    <select id="has-existing-website" name="hasExistingWebsite">
      <option value="yes">Yes</option>
      <option value="no">No</option>
    </select>
  </div>

  <div class="form-group" id="website-name-group">
    <label for="website-name">Website Name</label>
    <input
      type="text"
      id="website-name"
      name="websiteName"
      maxlength="100"
      placeholder="e.g., www.example.com"
    />
    <p class="form-error" id="website-name-error" role="alert" aria-live="polite"></p>
  </div>

  <div class="form-group">
    <label for="email">Email <span class="required" aria-hidden="true">*</span></label>
    <input
      type="email"
      id="email"
      name="email"
      required
      maxlength="254"
      autocomplete="email"
      aria-required="true"
    />
    <p class="form-error" id="email-error" role="alert" aria-live="polite"></p>
  </div>

  <div class="form-group">
    <label for="phone">Phone Number</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      maxlength="20"
      autocomplete="tel"
      placeholder="(555) 123-4567"
    />
    <p class="form-error" id="phone-error" role="alert" aria-live="polite"></p>
  </div>

  <div class="form-group">
    <label for="message">Message <span class="required" aria-hidden="true">*</span></label>
    <textarea
      id="message"
      name="message"
      required
      maxlength="1000"
      rows="5"
      aria-required="true"
    ></textarea>
    <p class="form-error" id="message-error" role="alert" aria-live="polite"></p>
  </div>

  <div id="form-status" class="form-status" role="alert" aria-live="polite"></div>

  <button type="submit" class="btn btn-primary form-submit">
    Send Message
  </button>
</form>

<div class="alternative-contact">
  <h3>Other Ways to Reach Us</h3>
  <p>
    Email: <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
  </p>
</div>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
    max-width: 600px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  label {
    font-weight: 600;
    font-size: var(--font-size-sm);
  }

  .required {
    color: var(--color-error);
  }

  input,
  textarea,
  select {
    padding: var(--spacing-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    min-height: var(--touch-target-min);
    background-color: var(--color-bg);
    transition: border-color var(--transition-fast);
  }

  input:focus,
  textarea:focus,
  select:focus {
    border-color: var(--color-primary);
  }

  input[aria-invalid="true"],
  textarea[aria-invalid="true"] {
    border-color: var(--color-error);
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-error {
    color: var(--color-error);
    font-size: var(--font-size-sm);
    min-height: 0;
  }

  .form-error:empty {
    display: none;
  }

  .form-status {
    padding: var(--spacing-4);
    border-radius: var(--radius-md);
    font-weight: 500;
  }

  .form-status:empty {
    display: none;
  }

  .form-status.success {
    background-color: var(--color-secondary-light);
    color: var(--color-secondary);
  }

  .form-status.error {
    background-color: #fef2f2;
    color: var(--color-error);
  }

  .form-submit {
    align-self: flex-start;
    min-width: 160px;
  }

  .form-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .alternative-contact {
    margin-top: var(--spacing-10);
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-border);
  }

  .alternative-contact h3 {
    margin-bottom: var(--spacing-4);
  }

  .alternative-contact p {
    margin-bottom: var(--spacing-2);
  }

  .alternative-contact a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  #website-name-group.hidden {
    display: none;
  }
</style>

<script>
  import { validateName, validateEmail, validatePhone, validateMessage, validateWebsiteName, validateForm } from '../scripts/form-validation';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const websiteSelect = document.getElementById('has-existing-website') as HTMLSelectElement;
  const websiteNameGroup = document.getElementById('website-name-group') as HTMLElement;
  const statusEl = document.getElementById('form-status') as HTMLElement;

  function showError(fieldId: string, message: string) {
    const input = document.getElementById(fieldId) as HTMLInputElement;
    const errorEl = document.getElementById(`${fieldId}-error`) as HTMLElement;
    if (input) {
      input.setAttribute('aria-invalid', 'true');
      input.setAttribute('aria-describedby', `${fieldId}-error`);
    }
    if (errorEl) errorEl.textContent = message;
  }

  function clearError(fieldId: string) {
    const input = document.getElementById(fieldId) as HTMLInputElement;
    const errorEl = document.getElementById(`${fieldId}-error`) as HTMLElement;
    if (input) {
      input.removeAttribute('aria-invalid');
      input.removeAttribute('aria-describedby');
    }
    if (errorEl) errorEl.textContent = '';
  }

  function toggleWebsiteName() {
    if (websiteSelect.value === 'yes') {
      websiteNameGroup.classList.remove('hidden');
    } else {
      websiteNameGroup.classList.add('hidden');
    }
  }

  websiteSelect.addEventListener('change', toggleWebsiteName);
  toggleWebsiteName();

  const fieldValidators: Record<string, (value: string) => string | null> = {
    name: validateName,
    email: validateEmail,
    phone: validatePhone,
    message: validateMessage,
    'website-name': validateWebsiteName,
  };

  Object.entries(fieldValidators).forEach(([fieldId, validator]) => {
    const input = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
    if (!input) return;

    input.addEventListener('blur', () => {
      const error = validator(input.value);
      if (error) {
        showError(fieldId, error);
      } else {
        clearError(fieldId);
      }
    });

    input.addEventListener('input', () => {
      const errorEl = document.getElementById(`${fieldId}-error`) as HTMLElement;
      if (errorEl && errorEl.textContent) {
        const error = validator(input.value);
        if (!error) clearError(fieldId);
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nameInput = document.getElementById('name') as HTMLInputElement;
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    const messageInput = document.getElementById('message') as HTMLTextAreaElement;
    const websiteNameInput = document.getElementById('website-name') as HTMLInputElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    const formData = {
      name: nameInput.value,
      email: emailInput.value,
      phone: phoneInput.value,
      message: messageInput.value,
      hasExistingWebsite: websiteSelect.value === 'yes',
      websiteName: websiteNameInput.value,
    };

    const result = validateForm(formData);

    ['name', 'email', 'phone', 'message', 'website-name'].forEach(clearError);

    if (!result.valid) {
      Object.entries(result.errors).forEach(([field, message]) => {
        const fieldId = field === 'websiteName' ? 'website-name' : field;
        showError(fieldId, message);
      });
      const firstErrorField = Object.keys(result.errors)[0];
      const fieldId = firstErrorField === 'websiteName' ? 'website-name' : firstErrorField;
      (document.getElementById(fieldId) as HTMLElement)?.focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    statusEl.textContent = '';
    statusEl.className = 'form-status';

    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 30000);

    try {
      const endpoint = form.getAttribute('action') || '/api/contact';
      const apiKey = form.dataset.apiKey;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(apiKey ? { 'x-api-key': apiKey } : {}),
        },
        body: JSON.stringify({
          ...formData,
          timestamp: new Date().toISOString(),
          userAgent: navigator.userAgent,
        }),
        signal: controller.signal,
      });

      clearTimeout(timeout);

      if (response.ok) {
        statusEl.textContent = 'Thank you! Your message has been sent. We\'ll get back to you soon.';
        statusEl.className = 'form-status success';
        form.reset();
        toggleWebsiteName();
      } else {
        const data = await response.json().catch(() => null);
        statusEl.textContent = data?.message || 'There was an error sending your message. Please try again or contact us directly.';
        statusEl.className = 'form-status error';
      }
    } catch (err: unknown) {
      clearTimeout(timeout);
      if (err instanceof Error && err.name === 'AbortError') {
        statusEl.textContent = 'The request timed out. Please try again or contact us directly.';
      } else {
        statusEl.textContent = 'There was a network error. Please check your connection and try again, or contact us directly.';
      }
      statusEl.className = 'form-status error';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
