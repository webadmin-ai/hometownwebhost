---
interface Props {
  heading: string;
  body: string;
  primaryText: string;
  primaryLink: string;
  secondaryText?: string;
  secondaryLink?: string;
}

const { heading, body, primaryText, primaryLink, secondaryText, secondaryLink } = Astro.props;
---

<section class="cta-band" aria-labelledby="cta-band-heading">
  <div class="cta-band-pattern" aria-hidden="true"></div>
  <div class="container cta-band-inner">
    <div class="cta-band-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    </div>
    <h2 id="cta-band-heading">{heading}</h2>
    <p>{body}</p>
    <div class="cta-band-buttons">
      <a href={primaryLink} class="btn-cta-primary">{primaryText}</a>
      {secondaryText && secondaryLink && (
        <a href={secondaryLink} class="btn-cta-ghost">{secondaryText}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    background: linear-gradient(135deg, #0f172a 0%, #1a3a6e 55%, #1a56db 100%);
    color: #ffffff;
    overflow: hidden;
    padding-block: var(--spacing-16);
  }

  @media (min-width: 768px) {
    .cta-band {
      padding-block: var(--spacing-20);
    }
  }

  .cta-band-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .cta-band-inner {
    position: relative;
    text-align: center;
    max-width: 620px;
  }

  .cta-band-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 68px;
    height: 68px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: #ffffff;
    margin-bottom: var(--spacing-6);
  }

  .cta-band-inner h2 {
    color: #ffffff;
    margin-bottom: var(--spacing-4);
  }

  .cta-band-inner p {
    font-size: var(--font-size-lg);
    opacity: 0.9;
    margin-bottom: var(--spacing-8);
    line-height: 1.6;
  }

  .cta-band-buttons {
    display: flex;
    gap: var(--spacing-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--touch-target-min);
    padding: var(--spacing-3) var(--spacing-8);
    background-color: var(--color-accent);
    color: #111827;
    font-weight: 700;
    font-size: var(--font-size-base);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .btn-cta-primary:hover {
    background-color: #d97706;
    transform: translateY(-1px);
  }

  .btn-cta-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--touch-target-min);
    padding: var(--spacing-3) var(--spacing-8);
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.35);
    font-weight: 600;
    font-size: var(--font-size-base);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .btn-cta-ghost:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }
</style>
