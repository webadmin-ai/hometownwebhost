---
import { siteConfig } from '../config';

const currentYear = new Date().getFullYear();
const hasSocial = siteConfig.socialMedia && Object.values(siteConfig.socialMedia).some(Boolean);
---

<footer class="site-footer">
  <div class="container footer-inner">
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href="/privacy/">Privacy Policy</a></li>
        <li><a href="/terms/">Terms of Service</a></li>
        <li><a href="/contact/">Contact Us</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <p>
        <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
      </p>
      <p>
        <a href={`tel:${siteConfig.contactPhone.replace(/[^\d+]/g, '')}`}>{siteConfig.contactPhone}</a>
      </p>
    </div>

    {hasSocial && (
      <div class="footer-social" aria-label="Social media links">
        {siteConfig.socialMedia?.facebook && (
          <a href={siteConfig.socialMedia.facebook} aria-label="Facebook" rel="noopener noreferrer" target="_blank">Facebook</a>
        )}
        {siteConfig.socialMedia?.twitter && (
          <a href={siteConfig.socialMedia.twitter} aria-label="Twitter" rel="noopener noreferrer" target="_blank">Twitter</a>
        )}
        {siteConfig.socialMedia?.linkedin && (
          <a href={siteConfig.socialMedia.linkedin} aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">LinkedIn</a>
        )}
        {siteConfig.socialMedia?.instagram && (
          <a href={siteConfig.socialMedia.instagram} aria-label="Instagram" rel="noopener noreferrer" target="_blank">Instagram</a>
        )}
      </div>
    )}

    <p class="footer-copyright">
      &copy; {currentYear} {siteConfig.name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-dark);
    color: var(--color-text-inverse);
    padding-block: var(--spacing-12);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    gap: var(--spacing-8);
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .footer-nav a {
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    color: #d1d5db;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-nav a:hover,
  .footer-nav a:focus {
    color: var(--color-text-inverse);
  }

  .footer-contact a {
    color: #d1d5db;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-contact a:hover,
  .footer-contact a:focus {
    color: var(--color-text-inverse);
  }

  .footer-contact p + p {
    margin-top: var(--spacing-2);
  }

  .footer-social {
    display: flex;
    gap: var(--spacing-4);
  }

  .footer-social a {
    color: #d1d5db;
    transition: color var(--transition-fast);
  }

  .footer-social a:hover,
  .footer-social a:focus {
    color: var(--color-text-inverse);
  }

  .footer-copyright {
    color: #9ca3af;
    font-size: var(--font-size-sm);
    padding-top: var(--spacing-8);
    border-top: 1px solid #374151;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-nav ul {
      flex-direction: row;
      gap: var(--spacing-6);
    }

    .footer-copyright {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1025px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-copyright {
      grid-column: 1 / -1;
    }
  }
</style>
