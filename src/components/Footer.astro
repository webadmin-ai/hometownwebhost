---
import { siteConfig } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-info">
      <a href="/" class="footer-logo">
        <span class="logo-icon">🏠</span>
        <span class="logo-text">{siteConfig.name}</span>
      </a>
      <p class="footer-tagline">{siteConfig.description}</p>
      
      <!-- Social Media Links (Req 11.7) -->
      {siteConfig.socialMedia && (
        <div class="footer-socials" aria-label="Social Media Accounts">
          {siteConfig.socialMedia.facebook && (
            <a href={siteConfig.socialMedia.facebook} class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
            </a>
          )}
          {siteConfig.socialMedia.twitter && (
            <a href={siteConfig.socialMedia.twitter} class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Twitter">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
              </svg>
            </a>
          )}
          {siteConfig.socialMedia.linkedin && (
            <a href={siteConfig.socialMedia.linkedin} class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Follow us on LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          )}
        </div>
      )}
    </div>

    <!-- Footer Links Navigation (Req 11.2, 11.3) -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul role="list" class="footer-links-list">
        <li>
          <a href="/privacy" class="footer-link">Privacy Policy</a>
        </li>
        <li>
          <a href="/terms" class="footer-link">Terms of Service</a>
        </li>
        <li>
          <a href="/contact" class="footer-link">Contact Support</a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p class="copyright">
      &copy; {currentYear} {siteConfig.name}. All rights reserved. Built with pride for small local businesses.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-dark);
    color: var(--color-text-light);
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xl);
    border-top: 1px solid var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: auto; /* Push to bottom of flex container */
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 768px) {
    .footer-container {
      grid-template-columns: 2fr 1fr;
      align-items: flex-start;
    }
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    align-items: flex-start;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-bg-white);
  }

  .footer-logo:hover {
    text-decoration: none;
    color: var(--color-primary-light);
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  .footer-tagline {
    color: rgba(255, 255, 255, 0.7);
    max-width: 400px;
    margin-bottom: 0;
  }

  /* Social Media Accounts (Req 11.7) */
  .footer-socials {
    display: flex;
    gap: var(--spacing-sm);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target-min);
    height: var(--touch-target-min);
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--color-text-light);
    transition: background-color 0.15s ease-in-out, color 0.15s ease-in-out;
  }

  .social-link:hover {
    background-color: var(--color-primary);
    color: var(--color-bg-white);
    text-decoration: none;
  }

  /* Footer Navigation links (Req 11.2, 11.3) */
  .footer-nav {
    display: flex;
    flex-direction: column;
  }

  .footer-links-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    padding: 0;
    margin: 0;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.7);
    display: inline-flex;
    align-items: center;
    padding: var(--spacing-xs) 0;
    font-weight: 500;
  }

  .footer-link:hover {
    color: var(--color-bg-white);
    text-decoration: underline;
  }

  /* Footer Bottom */
  .footer-bottom {
    padding-top: var(--spacing-lg);
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
  }

  .copyright {
    margin-bottom: 0;
    color: rgba(255, 255, 255, 0.5);
  }
</style>
