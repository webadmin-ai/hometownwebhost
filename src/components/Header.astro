---
import { siteConfig } from '../config';
import MobileMenu from './MobileMenu.astro';

const pathname = new URL(Astro.request.url).pathname;
const activeClass = (path: string) => {
  if (path === '/' && pathname === '/') return 'active';
  if (path !== '/' && pathname.startsWith(path)) return 'active';
  return '';
};

const navItems = [
  { label: 'Home', path: '/' },
  { label: 'Services', path: '/services' },
  { label: 'Pricing', path: '/pricing' },
  { label: 'About', path: '/about' },
  { label: 'Contact', path: '/contact' },
];
---

<header class="site-header">
  <div class="container header-container">
    <a href="/" class="logo-link" aria-label="Home Town Web Host Home">
      <span class="logo-icon">🏠</span>
      <span class="logo-text">{siteConfig.name}</span>
    </a>

    <!-- Desktop Navigation Menu (Req 7.3, 7.4) -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul role="list">
        {navItems.map(item => (
          <li>
            <a 
              href={item.path} 
              class={`nav-link ${activeClass(item.path)}`}
              aria-current={activeClass(item.path) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile Hamburger Menu Button (Req 7.2) -->
    <button 
      id="hamburger-menu-button" 
      class="hamburger-btn" 
      aria-haspopup="true" 
      aria-expanded="false" 
      aria-controls="mobile-menu-container"
      aria-label="Open navigation menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Drawer Overlay component -->
  <MobileMenu />
</header>

<style>
  .site-header {
    background-color: var(--color-bg-white);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 70px;
    padding-top: 0;
    padding-bottom: 0;
  }

  /* Logo Links */
  .logo-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .logo-link:hover {
    text-decoration: none;
    color: var(--color-primary-hover);
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  /* Desktop Navigation Links */
  .desktop-nav {
    display: none; /* Hidden on mobile (Req 7.1) */
  }

  .desktop-nav ul {
    display: flex;
    gap: var(--spacing-md);
  }

  .nav-link {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 4px;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  /* Active Menu Item Visual Highlight (Req 5.4) */
  .nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  /* Mobile Hamburger Button */
  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-dark);
    width: var(--touch-target-min); /* Req 7.5 */
    height: var(--touch-target-min); /* Req 7.5 */
  }

  /* Breakpoint transitions */
  @media (min-width: 768px) {
    .desktop-nav {
      display: block; /* Visible on tablet and desktop (Req 7.3, 7.4) */
    }

    .hamburger-btn {
      display: none; /* Hidden on larger screens */
    }
  }
</style>
