---
interface Props {
  heading: string;
  subheading: string;
  ctaText: string;
  ctaLink: string;
}

const { heading, subheading, ctaText, ctaLink } = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    <h1>{heading}</h1>
    <p class="hero-subheading">{subheading}</p>
    <a href={ctaLink} class="btn btn-primary hero-cta">{ctaText}</a>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #2563eb 50%, #1e40af 100%);
    color: var(--color-text-inverse);
    padding-block: var(--spacing-16);
  }

  .hero-inner {
    text-align: center;
    max-width: 800px;
  }

  .hero h1 {
    color: var(--color-text-inverse);
    margin-bottom: var(--spacing-6);
  }

  .hero-subheading {
    font-size: var(--font-size-lg);
    line-height: 1.6;
    margin-bottom: var(--spacing-8);
    opacity: 0.95;
  }

  .hero-cta {
    font-size: var(--font-size-lg);
    padding: var(--spacing-4) var(--spacing-8);
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius-md);
    font-weight: 700;
  }

  .hero-cta:hover {
    background-color: #d97706;
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: var(--spacing-20);
    }

    .hero-subheading {
      font-size: var(--font-size-xl);
    }
  }

  @media (min-width: 1025px) {
    .hero {
      padding-block: 6rem;
    }
  }
</style>
