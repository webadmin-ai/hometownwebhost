---
import { siteConfig } from '../config';

const pathname = new URL(Astro.request.url).pathname;
const activeClass = (path: string) => {
  if (path === '/' && pathname === '/') return 'active';
  if (path !== '/' && pathname.startsWith(path)) return 'active';
  return '';
};

const navItems = [
  { label: 'Home', path: '/' },
  { label: 'Services', path: '/services' },
  { label: 'Pricing', path: '/pricing' },
  { label: 'About', path: '/about' },
  { label: 'Contact', path: '/contact' },
];
---

<div id="mobile-menu-container" class="mobile-menu-overlay" aria-hidden="true">
  <div class="mobile-menu-drawer" role="dialog" aria-modal="true" aria-label="Mobile Navigation Menu">
    <div class="mobile-menu-header">
      <span class="logo-text">{siteConfig.name}</span>
      <button id="close-menu-button" class="close-btn" aria-label="Close navigation menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <ul role="list">
        {navItems.map(item => (
          <li>
            <a 
              href={item.path} 
              class={`mobile-nav-link ${activeClass(item.path)}`}
              aria-current={activeClass(item.path) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</div>

<script>
  // Mobile Menu Client Logic - Handles Toggles, Focus Traps & Accessibility
  const openBtn = document.getElementById('hamburger-menu-button');
  const closeBtn = document.getElementById('close-menu-button');
  const menuContainer = document.getElementById('mobile-menu-container');
  const drawer = menuContainer?.querySelector('.mobile-menu-drawer');
  
  if (openBtn && closeBtn && menuContainer && drawer) {
    const focusableElements = drawer.querySelectorAll('a, button');
    const firstFocusable = focusableElements[0] as HTMLElement;
    const lastFocusable = focusableElements[focusableElements.length - 1] as HTMLElement;

    const toggleMenu = (open: boolean) => {
      if (open) {
        menuContainer.classList.add('is-open');
        menuContainer.setAttribute('aria-hidden', 'false');
        openBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden'; // Prevents background scroll (Req 7.7)
        setTimeout(() => firstFocusable?.focus(), 100); // Focus trap initialization (Req 10.5)
      } else {
        menuContainer.classList.remove('is-open');
        menuContainer.setAttribute('aria-hidden', 'true');
        openBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        openBtn.focus(); // Restore focus (Req 10.5)
      }
    };

    openBtn.addEventListener('click', () => toggleMenu(true));
    closeBtn.addEventListener('click', () => toggleMenu(false));

    // Close menu when clicking on overlay background
    menuContainer.addEventListener('click', (e) => {
      if (e.target === menuContainer) {
        toggleMenu(false);
      }
    });

    // Handle Keyboard Accessibility within Menu drawer
    drawer.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        toggleMenu(false);
      }

      if (e.key === 'Tab') {
        if (e.shiftKey) { // Shift + Tab (Backward)
          if (document.activeElement === firstFocusable) {
            e.preventDefault();
            lastFocusable?.focus();
          }
        } else { // Tab (Forward)
          if (document.activeElement === lastFocusable) {
            e.preventDefault();
            firstFocusable?.focus();
          }
        }
      }
    });
  }
</script>

<style>
  /* Mobile Menu Container & Overlay */
  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
  }

  .mobile-menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* Drawer Structure */
  .mobile-menu-drawer {
    position: absolute;
    top: 0;
    left: 0;
    width: 80%;
    max-width: 320px;
    height: 100%;
    background-color: var(--color-bg-white);
    padding: var(--spacing-lg);
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
    transform: translateX(-100%);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }

  .mobile-menu-overlay.is-open .mobile-menu-drawer {
    transform: translateX(0);
  }

  /* Header inside drawer */
  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-md);
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-primary);
  }

  .close-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target-min);
    height: var(--touch-target-min);
  }

  /* Nav Links - Stacked on Mobile (Req 7.1) */
  .mobile-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .mobile-nav-link {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-dark);
    width: 100%;
    display: flex;
    align-items: center;
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid transparent;
  }

  .mobile-nav-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .mobile-nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
</style>
