---
interface Props {
  heading: string;
  subheading?: string;
}

const { heading, subheading } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero-dots" aria-hidden="true"></div>
  <div class="page-hero-orb" aria-hidden="true"></div>
  <div class="container page-hero-inner">
    <h1>{heading}</h1>
    {subheading && <p class="page-hero-sub">{subheading}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    background: linear-gradient(135deg, #0f172a 0%, #1a3a6e 55%, #1a56db 100%);
    color: #ffffff;
    padding-block: var(--spacing-16);
    overflow: hidden;
  }

  .page-hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .page-hero-orb {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: rgba(26, 86, 219, 0.22);
    filter: blur(80px);
    top: -120px;
    right: -80px;
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    max-width: 800px;
  }

  .page-hero-inner h1 {
    color: #ffffff;
    margin-bottom: 0;
  }

  .page-hero-sub {
    color: rgba(255, 255, 255, 0.88);
    font-size: var(--font-size-lg);
    line-height: 1.65;
    margin-top: var(--spacing-4);
    max-width: 680px;
  }

  @media (min-width: 768px) {
    .page-hero {
      padding-block: var(--spacing-20);
    }
  }
</style>
