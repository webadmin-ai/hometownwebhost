---
interface Props {
  planName: string;
  monthlyPrice: number;
  annualPrice: number;
  features: string[];
  isPopular?: boolean;
  promotionalPrice?: {
    monthly: number;
    annual: number;
    expiresAt: string;
  };
  additionalCosts?: {
    description: string;
    amount: number;
  }[];
  contactForPricing?: boolean;
  startingAt?: boolean;
  note?: string;
}

const {
  planName,
  monthlyPrice,
  annualPrice,
  features,
  isPopular = false,
  promotionalPrice,
  additionalCosts,
  contactForPricing = false,
  startingAt = false,
  note,
} = Astro.props;

function formatPrice(amount: number): string {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(amount);
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<article class:list={['pricing-card', { popular: isPopular }]}>
  {isPopular && <span class="popular-badge">Most Popular</span>}

  <h3 class="plan-name">{planName}</h3>

  {contactForPricing ? (
    <div class="plan-pricing">
      <p class="contact-pricing">Contact us for pricing</p>
    </div>
  ) : (
    <div class="plan-pricing">
      <div class="price-group">
        <span class="price-label">Monthly</span>
        {startingAt && <span class="price-prefix">Starting at</span>}
        {promotionalPrice ? (
          <div class="price-with-promo">
            <span class="price-original"><s>{formatPrice(monthlyPrice)}</s></span>
            <span class="price-amount promo">{formatPrice(promotionalPrice.monthly)}</span>
          </div>
        ) : (
          <span class="price-amount">{formatPrice(monthlyPrice)}</span>
        )}
        <span class="price-period">/month</span>
      </div>

      <div class="price-group">
        <span class="price-label">Annual</span>
        {startingAt && <span class="price-prefix">Starting at</span>}
        {promotionalPrice ? (
          <div class="price-with-promo">
            <span class="price-original"><s>{formatPrice(annualPrice)}</s></span>
            <span class="price-amount promo">{formatPrice(promotionalPrice.annual)}</span>
          </div>
        ) : (
          <span class="price-amount">{formatPrice(annualPrice)}</span>
        )}
        <span class="price-period">/year</span>
      </div>

      {promotionalPrice && (
        <p class="promo-expiry">
          Promotion ends {formatDate(promotionalPrice.expiresAt)}
        </p>
      )}

      {note && <p class="plan-note">{note}</p>}
    </div>
  )}

  <ul class="plan-features">
    {features.map(feature => (
      <li>{feature}</li>
    ))}
  </ul>

  {additionalCosts && additionalCosts.length > 0 && (
    <div class="additional-costs">
      <p class="additional-costs-label">Additional costs:</p>
      <ul>
        {additionalCosts.map(cost => (
          <li>
            {cost.description}: {cost.amount === 0 ? 'Included' : formatPrice(cost.amount)}
          </li>
        ))}
      </ul>
    </div>
  )}

  <a
    href={contactForPricing ? '/contact/' : '/contact/'}
    class:list={['btn', 'pricing-cta', isPopular ? 'btn-primary' : 'btn-secondary']}
  >
    {contactForPricing ? 'Contact Us' : 'Get Started'}
  </a>
</article>

<style>
  .pricing-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-6);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: box-shadow var(--transition-base);
  }

  .pricing-card:hover {
    box-shadow: var(--shadow-md);
  }

  .pricing-card.popular {
    border-color: var(--color-primary);
    border-width: 2px;
    box-shadow: var(--shadow-lg);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-primary);
    color: var(--color-text-inverse);
    padding: var(--spacing-1) var(--spacing-4);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    white-space: nowrap;
  }

  .plan-name {
    text-align: center;
    margin-bottom: var(--spacing-4);
    margin-top: var(--spacing-2);
  }

  .plan-pricing {
    text-align: center;
    margin-bottom: var(--spacing-6);
    padding-bottom: var(--spacing-6);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-pricing {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-primary);
  }

  .price-group {
    margin-bottom: var(--spacing-3);
  }

  .price-label {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .price-prefix {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    font-style: italic;
  }

  .price-amount {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    color: var(--color-text);
  }

  .price-amount.promo {
    color: var(--color-secondary);
  }

  .price-original {
    display: block;
    color: var(--color-text-light);
    font-size: var(--font-size-sm);
  }

  .price-period {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .promo-expiry {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    font-weight: 500;
    margin-top: var(--spacing-2);
  }

  .plan-note {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    font-style: italic;
    margin-top: var(--spacing-2);
  }

  .plan-features {
    flex-grow: 1;
    margin-bottom: var(--spacing-6);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .plan-features li {
    padding-left: var(--spacing-5);
    position: relative;
  }

  .plan-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    font-weight: 700;
  }

  .additional-costs {
    margin-bottom: var(--spacing-6);
    padding: var(--spacing-3);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
  }

  .additional-costs-label {
    font-weight: 600;
    margin-bottom: var(--spacing-2);
  }

  .additional-costs li {
    color: var(--color-text-light);
  }

  .pricing-cta {
    width: 100%;
    text-align: center;
  }
</style>
