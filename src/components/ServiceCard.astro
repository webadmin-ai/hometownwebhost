---
interface Props {
  title: string;
  description: string;
  icon?: string;
  features: string[];
  link?: string;
  linkLabel?: string;
}

const {
  title,
  description,
  icon = 'globe',
  features,
  link,
  linkLabel = 'Learn more',
} = Astro.props;

// Helper to determine icon SVG path
const getIconSvg = (iconName: string) => {
  switch (iconName) {
    case 'cpu':
      return `<rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line>`;
    case 'settings':
      return `<circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>`;
    case 'globe':
    default:
      return `<circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>`;
  }
};

const isAiService = icon === 'cpu';
---

<article class={`service-card ${isAiService ? 'ai-highlight' : ''}`}>
  <div class="card-header">
    <div class="icon-wrapper" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={getIconSvg(icon)}></svg>
    </div>
    <h3 class="card-title">{title}</h3>
  </div>

  <p class="card-description">{description}</p>

  <div class="card-features-section">
    <h4 class="features-heading sr-only">Key Features</h4>
    <ul class="features-list" role="list">
      {features.map(feature => (
        <li class="feature-item">
          <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="feature-text">{feature}</span>
        </li>
      ))}
    </ul>
  </div>

  {link && (
    <div class="card-actions">
      <a 
        href={link} 
        class={`btn ${isAiService ? 'btn-ai' : 'btn-secondary'} btn-full`}
        aria-label={`${linkLabel} regarding our ${title}`}
      >
        {linkLabel}
      </a>
    </div>
  )}
</article>

<style>
  .service-card {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }

  /* Specific visual styling for the AI features flagship card */
  .ai-highlight {
    border-color: var(--color-ai);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
  }

  .ai-highlight:hover {
    box-shadow: 0 12px 24px rgba(99, 102, 241, 0.2);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background-color: var(--color-primary-light);
    color: var(--color-primary);
  }

  .ai-highlight .icon-wrapper {
    background-color: var(--color-ai-light);
    color: var(--color-ai);
  }

  .card-title {
    margin: 0;
    font-size: 1.35rem;
  }

  .card-description {
    font-size: 0.95rem;
    margin-bottom: var(--spacing-lg);
    flex-grow: 1;
  }

  .card-features-section {
    margin-bottom: var(--spacing-xl);
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .check-icon {
    color: var(--color-success);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ai-highlight .check-icon {
    color: var(--color-ai);
  }

  .card-actions {
    margin-top: auto;
  }

  .btn-full {
    width: 100%;
    box-sizing: border-box;
  }
</style>
