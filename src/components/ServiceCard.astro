---
interface Props {
  title: string;
  description: string;
  icon?: string;
  features: string[];
  link?: string;
}

const { title, description, icon, features, link } = Astro.props;

const iconMap: Record<string, string> = {
  globe: '\u{1F310}',
  sparkles: '\u{2728}',
  wrench: '\u{1F527}',
};
const iconChar = icon ? iconMap[icon] || '' : '';
---

<article class="service-card">
  {iconChar && <span class="service-icon" aria-hidden="true">{iconChar}</span>}
  <h3 class="service-title">{title}</h3>
  <p class="service-description">{description}</p>
  <ul class="service-features">
    {features.map(feature => (
      <li>{feature}</li>
    ))}
  </ul>
  {link && (
    <a href={link} class="btn btn-secondary service-link" aria-label={`Learn more about ${title}`}>
      Learn More
    </a>
  )}
</article>

<style>
  .service-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-6);
    transition: box-shadow var(--transition-base);
  }

  .service-card:hover {
    box-shadow: var(--shadow-md);
  }

  .service-icon {
    display: block;
    font-size: var(--font-size-4xl);
    margin-bottom: var(--spacing-4);
  }

  .service-title {
    margin-bottom: var(--spacing-3);
  }

  .service-description {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-4);
  }

  .service-features {
    margin-bottom: var(--spacing-6);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .service-features li {
    padding-left: var(--spacing-5);
    position: relative;
  }

  .service-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    font-weight: 700;
  }

  .service-link {
    width: 100%;
  }
</style>
