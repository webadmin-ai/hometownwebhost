---
interface Props {
  quote: string;
  author: string;
  businessName?: string;
  businessType?: string;
}

const { quote, author, businessName, businessType } = Astro.props;
---

<blockquote class="testimonial">
  <p class="testimonial-quote">&ldquo;{quote}&rdquo;</p>
  <footer class="testimonial-attribution">
    <cite class="testimonial-author">{author}</cite>
    {(businessName || businessType) && (
      <span class="testimonial-business">
        {businessName && businessName}
        {businessName && businessType && ' — '}
        {businessType && businessType}
      </span>
    )}
  </footer>
</blockquote>

<style>
  .testimonial {
    background-color: var(--color-bg);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius-md);
    padding: var(--spacing-6);
    box-shadow: var(--shadow-sm);
  }

  .testimonial-quote {
    font-size: var(--font-size-lg);
    font-style: italic;
    line-height: 1.7;
    margin-bottom: var(--spacing-4);
    color: var(--color-text);
  }

  .testimonial-attribution {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .testimonial-author {
    font-weight: 600;
    font-style: normal;
  }

  .testimonial-business {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
</style>
