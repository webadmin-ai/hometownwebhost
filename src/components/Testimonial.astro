---
interface Props {
  quote: string;
  author: string;
  businessName?: string;
  businessType?: string;
}

const {
  quote,
  author,
  businessName,
  businessType,
} = Astro.props;
---

<blockquote class="testimonial-card">
  <div class="quote-icon" aria-hidden="true">“</div>
  
  <p class="testimonial-quote">{quote}</p>
  
  <footer class="testimonial-footer">
    <cite class="testimonial-author">
      <strong class="author-name">{author}</strong>
      {(businessName || businessType) && (
        <span class="author-business">
          {businessName}{businessName && businessType ? `, ${businessType}` : businessType}
        </span>
      )}
    </cite>
  </footer>
</blockquote>

<style>
  .testimonial-card {
    background-color: var(--color-bg-light);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 12px 12px 0;
    padding: var(--spacing-lg) var(--spacing-xl);
    position: relative;
    display: flex;
    flex-direction: column;
    margin: 0;
    height: 100%;
  }

  .quote-icon {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-lg);
    font-size: 4rem;
    line-height: 1;
    font-family: Georgia, serif;
    color: rgba(2, 82, 165, 0.08);
    font-weight: bold;
    user-select: none;
  }

  .testimonial-quote {
    font-size: clamp(0.975rem, 2vw, 1.05rem);
    line-height: 1.6;
    color: var(--color-text-dark);
    font-style: italic;
    margin-bottom: var(--spacing-md);
    position: relative;
    z-index: 1;
  }

  .testimonial-footer {
    margin-top: auto;
    font-style: normal;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .author-name {
    color: var(--color-text-dark);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .author-business {
    font-weight: 500;
    opacity: 0.85;
    margin-top: 2px;
  }
</style>
