---
interface Props {
  quote: string;
  author: string;
  businessName?: string;
  businessType?: string;
}

const { quote, author, businessName, businessType } = Astro.props;

const initials = author
  .split(' ')
  .map(n => n[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<blockquote class="testimonial">
  <div class="testimonial-stars" aria-label="5 out of 5 stars">
    {[1,2,3,4,5].map(() => (
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b" stroke-width="1" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>
  <p class="testimonial-quote">&ldquo;{quote}&rdquo;</p>
  <footer class="testimonial-attribution">
    <div class="testimonial-avatar" aria-hidden="true">{initials}</div>
    <div class="testimonial-meta">
      <cite class="testimonial-author">{author}</cite>
      {(businessName || businessType) && (
        <span class="testimonial-business">
          {businessName && businessName}
          {businessName && businessType && ' — '}
          {businessType && businessType}
        </span>
      )}
    </div>
  </footer>
</blockquote>

<style>
  .testimonial {
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--spacing-6);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition-base);
  }

  .testimonial:hover {
    box-shadow: var(--shadow-lg);
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
    margin-bottom: var(--spacing-4);
  }

  .testimonial-quote {
    font-size: var(--font-size-base);
    font-style: italic;
    line-height: 1.75;
    color: var(--color-text);
    flex: 1;
    margin-bottom: var(--spacing-5);
  }

  .testimonial-attribution {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
  }

  .testimonial-avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-primary-light);
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonial-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-author {
    font-weight: 600;
    font-style: normal;
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .testimonial-business {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
  }
</style>
