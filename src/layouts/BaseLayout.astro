---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';
import '../styles/reset.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const { title, description, ogImage, canonicalURL, noindex } = Astro.props;

const pageTitle = title.includes(siteConfig.name)
  ? title
  : siteConfig.seo.titleTemplate.replace('%s', title);

const ogImg = ogImage || siteConfig.seo.defaultOgImage;
const canonical = canonicalURL || new URL(Astro.url.pathname, siteConfig.url).href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteConfig.name,
  url: siteConfig.url,
  logo: new URL('/images/hometown-logo.svg', siteConfig.url).href,
  description: siteConfig.description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImg, siteConfig.url).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImg, siteConfig.url).href} />

    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
