---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found - Home Town Web Host"
  description="The page you are looking for could not be found. Return to our homepage to explore our web hosting services."
>
  <section class="section error-page">
    <div class="container error-inner">
      <h1>404</h1>
      <p class="error-message">Sorry, the page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn btn-primary">Return to Homepage</a>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    min-height: 50vh;
    display: flex;
    align-items: center;
  }

  .error-inner {
    text-align: center;
    max-width: 500px;
  }

  .error-inner h1 {
    font-size: 6rem;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: var(--spacing-4);
  }

  .error-message {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-8);
  }
</style>
