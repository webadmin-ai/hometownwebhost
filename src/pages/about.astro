---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout
  title="About Home Town Web Host - Our Mission and Story"
  description="Learn about Home Town Web Host, our mission to empower small local businesses with affordable, AI-enabled web hosting solutions."
>
  <PageHeader
    heading="About Home Town Web Host"
    subheading="We believe every local business deserves a professional online presence — without needing a computer science degree or a massive budget."
  />

  <section class="section" aria-labelledby="mission-heading">
    <div class="container content-wrapper">
      <div class="section-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h2 id="mission-heading">Our Mission</h2>
      <p>
        At Home Town Web Host, our mission is to empower small local businesses and individuals with affordable, reliable web hosting that makes getting online simple and stress-free. We believe every local restaurant, landscaping company, plumbing service, electrical contractor, and roofing business deserves a professional online presence — without needing a computer science degree or a massive budget. We are committed to bridging the technology gap for small business owners by providing hosting solutions that are not only powerful and reliable but also genuinely easy to use, backed by real people who care about your success.
      </p>
    </div>
  </section>

  <section class="section alt-bg" aria-labelledby="customers-heading">
    <div class="container content-wrapper">
      <div class="section-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <h2 id="customers-heading">Who We Serve</h2>
      <p>
        We specialize in serving small local businesses and individuals who need a reliable online presence. Our customers include:
      </p>
      <ul class="audience-list">
        <li>
          <div class="audience-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2h18l-2 7H5L3 2z"/><path d="M5 9v11a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V9"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
          </div>
          <div>
            <h3>Restaurants &amp; Cafes</h3>
            <p>From family diners to specialty cafes, we help food businesses showcase their menus, hours, and location to hungry local customers.</p>
          </div>
        </li>
        <li>
          <div class="audience-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div>
            <h3>Landscapers &amp; Lawn Care</h3>
            <p>We help outdoor service professionals display their work, collect leads, and build credibility with before-and-after galleries.</p>
          </div>
        </li>
        <li>
          <div class="audience-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div>
            <h3>General Contractors</h3>
            <p>Plumbers, electricians, roofers, and other tradespeople use our hosting to establish trust, list services, and capture new business.</p>
          </div>
        </li>
        <li>
          <div class="audience-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <h3>Individuals</h3>
            <p>Personal bloggers, photographers, artists, and hobbyists who want their own corner of the internet at an affordable price.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="local-heading">
    <div class="container content-wrapper">
      <div class="section-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <h2 id="local-heading">Supporting Local Businesses</h2>
      <p>
        We understand that local businesses are the backbone of every community. That's why we go beyond just hosting — we provide the tools, support, and guidance small business owners need to succeed online. Our AI-powered website management feature was designed specifically for busy business owners who want to keep their site up to date without hiring a developer or spending hours learning complicated software. We're proud to help local businesses compete in the digital age while keeping costs manageable.
      </p>
    </div>
  </section>

  <section class="section alt-bg" aria-labelledby="story-heading">
    <div class="container content-wrapper">
      <div class="section-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      </div>
      <h2 id="story-heading">Our Story</h2>
      <p>
        Home Town Web Host was founded with a simple observation: most web hosting companies are built for developers, agencies, and tech-savvy users — not for the local plumber, the neighborhood restaurant, or the independent landscaper. We saw small business owners struggling with overcomplicated hosting platforms, paying too much for features they'd never use, and feeling lost when they needed help.
      </p>
      <p>
        So we built something different. Home Town Web Host strips away the complexity and gives small businesses exactly what they need: reliable hosting, simple tools, and friendly support. When we added our AI website management feature, it was a game-changer — business owners could finally update their own websites without any technical knowledge, just by describing what they wanted in plain English.
      </p>
      <p>
        Today, we're proud to serve hundreds of local businesses and individuals across the country, helping them build and maintain their online presence with confidence.
      </p>
    </div>
  </section>

  <CtaSection
    heading="Ready to Get Started?"
    body="Join hundreds of local businesses who trust Home Town Web Host for their online presence."
    primaryText="View Plans"
    primaryLink="/pricing/"
    secondaryText="Contact Us"
    secondaryLink="/contact/"
  />
</BaseLayout>

<style>
  .content-wrapper {
    max-width: 800px;
  }

  .section-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: var(--radius-lg);
    margin-bottom: var(--spacing-5);
  }

  .content-wrapper p {
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: var(--spacing-4);
  }

  .content-wrapper h2 {
    margin-bottom: var(--spacing-5);
  }

  .alt-bg {
    background-color: var(--color-bg-alt);
  }

  .audience-list {
    margin-top: var(--spacing-6);
    display: grid;
    gap: var(--spacing-5);
  }

  @media (min-width: 768px) {
    .audience-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .audience-list li {
    display: flex;
    gap: var(--spacing-4);
    padding: var(--spacing-5);
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    transition: box-shadow var(--transition-base);
  }

  .audience-list li:hover {
    box-shadow: var(--shadow-md);
  }

  .audience-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: var(--radius-md);
    margin-top: 2px;
  }

  .audience-list h3 {
    font-size: var(--font-size-base);
    font-weight: 700;
    margin-bottom: var(--spacing-2);
    color: var(--color-primary);
  }

  .audience-list p {
    color: var(--color-text-light);
    font-size: var(--font-size-sm);
    margin-bottom: 0;
    line-height: 1.6;
  }
</style>
