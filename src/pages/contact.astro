---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Home Town Web Host - Get in Touch"
  description="Have questions about our web hosting services? Contact Home Town Web Host today. We are here to help your small business get online."
>
  <section class="section page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="page-intro">
        Have questions about our hosting services? Want to get started? We'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="contact-form-heading">
    <div class="container">
      <h2 id="contact-form-heading">Send Us a Message</h2>
      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-bg-alt);
    padding-bottom: var(--spacing-8);
  }

  .page-intro {
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
    margin-top: var(--spacing-4);
    max-width: 700px;
  }
</style>
