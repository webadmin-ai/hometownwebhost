---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="Contact Home Town Web Host - Get in Touch"
  description="Have questions about our web hosting services? Contact Home Town Web Host today. We are here to help your small business get online."
>
  <PageHeader
    heading="Contact Us"
    subheading="Have questions about our hosting services? Want to get started? We'd love to hear from you — a real person will respond."
  />

  <section class="section" aria-labelledby="contact-form-heading">
    <div class="container contact-layout">

      <!-- Info sidebar -->
      <aside class="contact-info">
        <h2 id="contact-info-heading">Get in Touch</h2>
        <p class="contact-info-intro">We typically respond within one business day.</p>

        <div class="info-cards">
          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="info-label">Email</p>
              <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="info-label">Phone</p>
              <a href={`tel:${siteConfig.contactPhone.replace(/[^\d+]/g, '')}`}>{siteConfig.contactPhone}</a>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="info-label">Support Hours</p>
              <p class="info-value">24/7 — always available</p>
            </div>
          </div>
        </div>

        <div class="response-promise">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Real people, no bots
        </div>
      </aside>

      <!-- Form -->
      <div class="contact-form-wrap">
        <h2 id="contact-form-heading">Send Us a Message</h2>
        <ContactForm />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    gap: var(--spacing-12);
    align-items: start;
  }

  @media (min-width: 1025px) {
    .contact-layout {
      grid-template-columns: 1fr 2fr;
    }
  }

  /* Info sidebar */
  .contact-info h2 {
    margin-bottom: var(--spacing-2);
  }

  .contact-info-intro {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-6);
  }

  .info-cards {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-6);
  }

  .info-card {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-4);
    padding: var(--spacing-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: var(--radius-md);
  }

  .info-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-1);
  }

  .info-card a {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: none;
  }

  .info-card a:hover {
    text-decoration: underline;
  }

  .info-value {
    font-weight: 500;
    color: var(--color-text);
  }

  .response-promise {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-secondary);
    background: var(--color-secondary-light);
    padding: var(--spacing-2) var(--spacing-4);
    border-radius: var(--radius-full);
  }

  .response-promise svg {
    flex-shrink: 0;
  }

  /* Form section */
  .contact-form-wrap h2 {
    margin-bottom: var(--spacing-6);
  }
</style>
