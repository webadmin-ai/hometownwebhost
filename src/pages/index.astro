---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Testimonial from '../components/Testimonial.astro';
import { getCollection } from 'astro:content';

const testimonials = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Affordable Web Hosting for Small Businesses"
  description="Home Town Web Host provides affordable, AI-enabled web hosting for small local businesses and individuals. Get your business online today."
>
  <Hero
    heading="Home Town Web Host"
    subheading="Affordable, AI-powered web hosting built for small local businesses and individuals. Get your restaurant, landscaping business, or personal site online — no tech skills required."
    ctaText="View Our Plans"
    ctaLink="/pricing/"
  />

  <section class="section services-overview" aria-labelledby="services-heading">
    <div class="container">
      <h2 id="services-heading">Our Hosting Services</h2>
      <p class="section-subtitle">
        Web hosting designed for small local businesses — restaurants, landscapers, contractors, and individuals who want their own personal website.
      </p>
      <div class="services-grid">
        {services.map(service => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            icon={service.data.icon}
            features={service.data.features.slice(0, 4)}
            link="/services/"
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section testimonials-section" aria-labelledby="testimonials-heading">
    <div class="container">
      <h2 id="testimonials-heading">What Our Customers Say</h2>
      <div class="testimonials-grid">
        {testimonials.map(testimonial => (
          <Testimonial
            quote={testimonial.data.quote}
            author={testimonial.data.author}
            businessName={testimonial.data.businessName}
            businessType={testimonial.data.businessType}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section" aria-labelledby="cta-heading">
    <div class="container cta-inner">
      <h2 id="cta-heading">Ready to Get Your Business Online?</h2>
      <p>Join hundreds of local businesses who trust Home Town Web Host for their online presence.</p>
      <div class="cta-buttons">
        <a href="/pricing/" class="btn btn-primary">See Pricing</a>
        <a href="/contact/" class="btn btn-secondary">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-subtitle {
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
    margin-top: var(--spacing-3);
    margin-bottom: var(--spacing-8);
    max-width: 700px;
  }

  .services-grid {
    display: grid;
    gap: var(--spacing-6);
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1025px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .testimonials-section {
    background-color: var(--color-bg-alt);
  }

  .testimonials-grid {
    display: grid;
    gap: var(--spacing-6);
    margin-top: var(--spacing-8);
  }

  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1025px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e40af 100%);
    color: var(--color-text-inverse);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
  }

  .cta-inner h2 {
    color: var(--color-text-inverse);
    margin-bottom: var(--spacing-4);
  }

  .cta-inner p {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-8);
    opacity: 0.95;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-buttons .btn-secondary {
    color: var(--color-text-inverse);
    border-color: var(--color-text-inverse);
  }

  .cta-buttons .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.15);
  }
</style>
