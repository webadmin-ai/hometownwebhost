---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import { getCollection } from 'astro:content';

const plans = (await getCollection('pricing')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Transparent Web Hosting Pricing and Plans"
  description="View our affordable web hosting plans starting at $4.99/month. Basic, AI-enabled, and custom hosting for small businesses and individuals."
>
  <section class="section page-header">
    <div class="container">
      <h1>Simple, Transparent Pricing</h1>
      <p class="page-intro">
        Choose the hosting plan that fits your needs. No hidden fees, no surprises.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="plans-heading">
    <div class="container">
      <h2 id="plans-heading" class="sr-only">Hosting Plans</h2>
      <div class="pricing-grid">
        {plans.map(plan => (
          <PricingCard
            planName={plan.data.planName}
            monthlyPrice={plan.data.monthlyPrice}
            annualPrice={plan.data.annualPrice}
            features={plan.data.features}
            isPopular={plan.data.isPopular}
            promotionalPrice={plan.data.promotionalPricing}
            additionalCosts={plan.data.additionalCosts}
            contactForPricing={plan.data.contactForPricing}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section pricing-notes" aria-labelledby="notes-heading">
    <div class="container">
      <h2 id="notes-heading">Good to Know</h2>
      <div class="notes-grid">
        <div class="note">
          <h3>Annual Savings</h3>
          <p>Save up to 17% when you choose annual billing on any plan.</p>
        </div>
        <div class="note">
          <h3>No Setup Fees</h3>
          <p>All plans include free setup and onboarding support.</p>
        </div>
        <div class="note">
          <h3>30-Day Guarantee</h3>
          <p>Not satisfied? Get a full refund within the first 30 days.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section" aria-labelledby="pricing-cta">
    <div class="container cta-inner">
      <h2 id="pricing-cta">Need Help Choosing?</h2>
      <p>Our team is happy to help you find the perfect plan for your business.</p>
      <a href="/contact/" class="btn btn-primary">Contact Us</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-bg-alt);
    padding-bottom: var(--spacing-8);
  }

  .page-intro {
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
    margin-top: var(--spacing-4);
    max-width: 700px;
  }

  .pricing-grid {
    display: grid;
    gap: var(--spacing-6);
    align-items: start;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1025px) {
    .pricing-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .pricing-notes {
    background-color: var(--color-bg-alt);
  }

  .notes-grid {
    display: grid;
    gap: var(--spacing-6);
    margin-top: var(--spacing-6);
  }

  @media (min-width: 768px) {
    .notes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .note {
    padding: var(--spacing-6);
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .note h3 {
    margin-bottom: var(--spacing-2);
  }

  .note p {
    color: var(--color-text-light);
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e40af 100%);
    color: var(--color-text-inverse);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
  }

  .cta-inner h2 {
    color: var(--color-text-inverse);
    margin-bottom: var(--spacing-4);
  }

  .cta-inner p {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-8);
    opacity: 0.95;
  }
</style>
