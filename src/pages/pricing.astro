---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaSection from '../components/CtaSection.astro';
import PricingCard from '../components/PricingCard.astro';
import { getCollection } from 'astro:content';

const plans = (await getCollection('pricing')).sort((a, b) => a.data.order - b.data.order);

const notes = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Annual Savings',
    body: 'Save up to 17% when you choose annual billing on any plan.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
    title: 'No Setup Fees',
    body: 'All plans include free setup and onboarding support.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: '30-Day Guarantee',
    body: 'Not satisfied? Get a full refund within the first 30 days.',
  },
];
---

<BaseLayout
  title="Transparent Web Hosting Pricing and Plans"
  description="View our affordable web hosting plans starting at $4.99/month. Basic, AI-enabled, and custom hosting for small businesses and individuals."
>
  <PageHeader
    heading="Simple, Transparent Pricing"
    subheading="Choose the hosting plan that fits your needs. No hidden fees, no surprises."
  />

  <section class="section" aria-labelledby="plans-heading">
    <div class="container">
      <h2 id="plans-heading" class="sr-only">Hosting Plans</h2>
      <div class="pricing-grid">
        {plans.map(plan => (
          <PricingCard
            planName={plan.data.planName}
            monthlyPrice={plan.data.monthlyPrice}
            annualPrice={plan.data.annualPrice}
            features={plan.data.features}
            isPopular={plan.data.isPopular}
            promotionalPrice={plan.data.promotionalPricing}
            additionalCosts={plan.data.additionalCosts}
            contactForPricing={plan.data.contactForPricing}
            startingAt={plan.data.startingAt}
          />
        ))}
      </div>
      <p class="domain-note">
        Don't have a domain name yet? No problem — you can purchase your own custom domain on your own, or Home Town Web Host can handle the entire process for you for a small additional fee. Pricing above covers web hosting only; email forwarding to your personal email (Eg. user@gmail.com) is included; full email hosting (sending email from yourname@domain.com) is available as an add-on for an additional cost.
      </p>
    </div>
  </section>

  <section class="section pricing-notes" aria-labelledby="notes-heading">
    <div class="container">
      <h2 id="notes-heading">Good to Know</h2>
      <div class="notes-grid">
        {notes.map(note => (
          <div class="note">
            <div class="note-icon" set:html={note.icon}></div>
            <h3>{note.title}</h3>
            <p>{note.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaSection
    heading="Need Help Choosing?"
    body="Our team is happy to help you find the perfect plan for your business."
    primaryText="Contact Us"
    primaryLink="/contact/"
    secondaryText="View Services"
    secondaryLink="/services/"
  />
</BaseLayout>

<style>
  .pricing-grid {
    display: grid;
    gap: var(--spacing-6);
    align-items: start;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1025px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .domain-note {
    max-width: 900px;
    margin: var(--spacing-8) auto 0;
    text-align: center;
    color: var(--color-text-light);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .pricing-notes {
    background-color: var(--color-bg-alt);
  }

  .pricing-notes h2 {
    margin-bottom: var(--spacing-8);
  }

  .notes-grid {
    display: grid;
    gap: var(--spacing-6);
  }

  @media (min-width: 768px) {
    .notes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .note {
    padding: var(--spacing-6);
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .note:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .note-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: var(--radius-lg);
    margin-bottom: var(--spacing-4);
  }

  .note h3 {
    margin-bottom: var(--spacing-2);
  }

  .note p {
    color: var(--color-text-light);
    line-height: 1.65;
  }
</style>
