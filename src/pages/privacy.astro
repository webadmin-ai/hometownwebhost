---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Privacy Policy | Home Town Web Host";
const description = "Read the Privacy Policy for Home Town Web Host. Understand how we collect, store, and safeguard your personal information and business website data.";
---

<BaseLayout title={title} description={description}>
  <section class="section legal-page" aria-labelledby="legal-heading">
    <div class="container legal-container">
      <h1 id="legal-heading">Privacy Policy</h1>
      <p class="last-updated">Last Updated: June 21, 2026</p>
      
      <p class="lead">
        At Home Town Web Host, we protect your privacy as we would our own neighbors'. This Privacy Policy explains how we collect, use, and safeguard the information you provide when using our public marketing website and web hosting services.
      </p>

      <h2>1. Information We Collect</h2>
      <p>
        When you submit an inquiry on our Contact Form or sign up for our services, we collect information necessary to assist you. This includes:
      </p>
      <ul>
        <li>Your name (maximum 100 characters)</li>
        <li>Your email address (maximum 254 characters)</li>
        <li>Your phone number (maximum 20 characters)</li>
        <li>Details about your existing website (if migrating)</li>
        <li>Your inquiry or support message (maximum 1000 characters)</li>
        <li>Technical telemetry (such as your browser's user agent and submission timestamps)</li>
      </ul>

      <h2>2. How We Use Your Information</h2>
      <p>
        We use the collected information solely to provide neighborly, top-tier hosting services, including:
      </p>
      <ul>
        <li>Answering your service inquiries and setting up new accounts</li>
        <li>Processing migrations from your existing websites</li>
        <li>Fulfilling support requests and technical maintenance</li>
        <li>Applying conversational AI website updates on your behalf if you subscribe to our AI-Enabled plans</li>
      </ul>

      <h2>3. Information Protection and Retention</h2>
      <p>
        We do not sell, trade, or transfer your personal or business website information to outside parties. Your data is stored on secure, local-cloud server networks protected by standard encryption protocols.
      </p>
      <p>
        We retain your contact inquiries for up to two years to maintain high-quality service records, or for the duration of your hosting relationship with us. You can request the removal of your contact information at any time by contacting us directly.
      </p>

      <h2>4. Cookies and Web Telemetry</h2>
      <p>
        Our website uses minor, non-invasive cookies solely to maintain navigation preferences (such as your choice between monthly and annual billing) and ensure accessible keyboard focus. We do not engage in invasive behavioral tracking or cross-site advertisement cookies.
      </p>

      <h2>5. Contact Us</h2>
      <p>
        If you have any questions or concerns regarding this Privacy Policy, please reach out to us at:
      </p>
      <p class="contact-details">
        📧 Email: <a href="mailto:info@hometownwebhost.com">info@hometownwebhost.com</a><br />
        📞 Phone: +1-800-555-HOST
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-page {
    background-color: var(--color-bg-white);
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxxl);
  }

  .legal-container {
    max-width: 800px;
  }

  .last-updated {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xl);
  }

  .lead {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-text-dark);
    margin-bottom: var(--spacing-xl);
  }

  h2 {
    font-size: 1.35rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    color: var(--color-text-dark);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-xs);
  }

  p, li {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
  }

  ul {
    margin-bottom: var(--spacing-lg);
    padding-left: var(--spacing-xl);
  }

  li {
    margin-bottom: var(--spacing-xs);
  }

  .contact-details {
    background-color: var(--color-bg-light);
    border: 1px solid var(--color-border);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: 8px;
    margin-top: var(--spacing-md);
  }

  .contact-details a {
    color: var(--color-primary);
    font-weight: 600;
    min-height: auto;
    min-width: auto;
    display: inline;
  }
</style>
