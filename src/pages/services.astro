---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

// Fetch service collection sorted by order
const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);

// Render markdown bodies (Astro 6 render function)
const renderedServices = await Promise.all(
  sortedServices.map(async (service) => {
    const { Content } = await render(service);
    return { service, Content };
  })
);

// Fetch pricing specs for tech specs table
const pricingPlans = await getCollection('pricing');
const sortedPlans = pricingPlans.sort((a, b) => a.data.order - b.data.order);

// Benefits for local businesses - Req 2.3
const benefits = [
  {
    title: "Save Crucial Business Time",
    description: "Instead of wasting hours battling with complicated website builders or coding, just talk in plain English. Your site is updated in seconds, leaving you free to run your business.",
    icon: "⏱️"
  },
  {
    title: "Always Up-to-Date Customer Info",
    description: "Keep your restaurant's daily specials, winter hours, or service lists fresh. Active updates mean better search engine rankings and happier local customers.",
    icon: "✨"
  },
  {
    title: "Hometown Reliability & Support",
    description: "We aren't a massive corporate hosting giant. We are your neighbors. We understand the local community, support local commerce, and provide real support whenever you call.",
    icon: "🤝"
  }
];

const title = "Our Web Hosting Services | Home Town Web Host";
const description = "Learn about our reliable hosting services and revolutionary plain-English AI website editor. Tailored for local restaurants, contractors, and builders.";
---

<BaseLayout title={title} description={description}>
  <!-- Services Hero Section - Req 2.1 -->
  <Hero 
    heading="Hosting Services & Features" 
    subheading="Reliable web hosting plans coupled with state-of-the-art AI-powered management that grows with your local business."
    ctaText="View Pricing Plans"
    ctaLink="/pricing"
    isAiTheme={true}
  />

  <!-- Benefits Section for Small Local Businesses - Req 2.3 -->
  <section class="section benefits-section" aria-labelledby="benefits-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-tag ai-tag">Why Choose Us</span>
        <h2 id="benefits-heading">Tailored Benefits for Local Business Owners</h2>
        <p class="section-intro">Unlike giant hosting companies, we structure our services around the daily realities of busy local contractors, restaurant owners, and tradespeople.</p>
      </div>

      <div class="grid-1-2-3">
        {benefits.map(benefit => (
          <div class="benefit-card">
            <span class="benefit-icon" aria-hidden="true">{benefit.icon}</span>
            <h3 class="benefit-title">{benefit.title}</h3>
            <p class="benefit-desc">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Detailed Service Descriptions (Req 2.2) -->
  <section class="section services-detail-section" aria-labelledby="details-heading">
    <div class="container">
      <h2 id="details-heading" class="sr-only">Detailed Service Descriptions</h2>
      
      <div class="services-stack">
        {renderedServices.map(({ service, Content }, index) => {
          const isAi = service.data.icon === 'cpu';
          return (
            <article id={service.id} class={`service-detail-item ${isAi ? 'ai-item' : ''}`}>
              <div class="service-detail-grid">
                <div class="service-detail-content">
                  <span class="detail-number">0{index + 1}</span>
                  <h2>{service.data.title}</h2>
                  <p class="detail-lead">{service.data.description}</p>
                  
                  {isAi && (
                    <!-- AI Feature specific highlights - Req 2.2 -->
                    <div class="ai-addon-box">
                      <h4>💡 Innovative Plain-English Assistant</h4>
                      <p>
                        Our signature AI feature is available as a <strong>fixed-cost monthly add-on</strong>. Simply speak or type plain English to request changes to your hours, text, or menus, and the AI instantly applies the updates. No complex software or hiring developers required.
                      </p>
                    </div>
                  )}

                  {!isAi && service.data.title.includes("Basic") && (
                    <!-- Manual updates encouragement - Req 2.2 -->
                    <div class="manual-pricing-notice">
                      <h4>✏️ Making Manual Website Updates?</h4>
                      <p>
                        Our Basic plans support standard manual file transfer. Because pricing varies depending on the type and complexity of your website, we encourage you to <a href="/contact">visit our Contact Page</a> to get a precise pricing quote tailored to your exact site layout.
                      </p>
                    </div>
                  )}

                  <div class="markdown-body">
                    <Content />
                  </div>
                </div>

                <div class="service-detail-sidebar">
                  <div class="sidebar-box">
                    <h3>Included Features</h3>
                    <ul role="list" class="feature-checklist">
                      {service.data.features.map(feature => (
                        <li>
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="sidebar-box">
                    <h3>Best Suited For</h3>
                    <ul role="list" class="audience-list">
                      {service.data.targetAudience.map(audience => (
                        <li>🎯 {audience}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Technical Specifications Table (Req 2.4, 2.5) -->
  <section class="section tech-specs-section" aria-labelledby="specs-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Specifications</span>
        <h2 id="specs-heading">Plan Technical Specifications</h2>
        <p class="section-intro">Compare the hosting server specs across our main hometown hosting packages.</p>
      </div>

      <div class="table-wrapper">
        <table class="specs-table">
          <thead>
            <tr>
              <th scope="col">Server Feature</th>
              <th scope="col">Basic Personal</th>
              <th scope="col">Basic Business</th>
              <th scope="col">AI-Enabled Business</th>
              <th scope="col">Custom Solutions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">Disk Space</th>
              <td>1 GB SSD</td>
              <td>5 GB SSD</td>
              <td>10 GB SSD</td>
              <td>Flexible / Tailor-made</td>
            </tr>
            <tr>
              <th scope="row">Monthly Bandwidth</th>
              <td>10 GB</td>
              <td>50 GB</td>
              <td>Unlimited</td>
              <td>Uncapped Dedication</td>
            </tr>
            <tr>
              <th scope="row">Supported Domains</th>
              <td>1 personal domain</td>
              <td>1 custom domain</td>
              <td>1 custom domain</td>
              <td>Multiple / Unlimited</td>
            </tr>
            <tr>
              <th scope="row">Custom Email Accounts</th>
              <td>None</td>
              <td>3 custom addresses</td>
              <td>5 custom addresses</td>
              <td>Bespoke setups</td>
            </tr>
            <tr>
              <th scope="row">AI English Updates</th>
              <td class="unsupported">✖ Not Included</td>
              <td class="unsupported">✖ Not Included</td>
              <td class="supported">✔ Included (Add-on)</td>
              <td>Custom integrations</td>
            </tr>
            <tr>
              <th scope="row">Technical Support</th>
              <td>Email support (24h)</td>
              <td>Email & Phone support</td>
              <td>Priority 24/7 support</td>
              <td>Dedicated Account Mgr</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Acceptance Criterion 2.5: Message indicating specifications pending if unavailable -->
      <div class="specs-pending-alert">
        <p class="pending-text">
          ℹ️ <strong>Note on Technical Specifications:</strong> Detailed hardware specifications for advanced high-traffic clusters are currently pending final server testing and optimization. Full benchmarks will be published shortly.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--spacing-xxl);
  }

  .section-tag {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-primary);
    letter-spacing: 1px;
    display: inline-block;
    margin-bottom: var(--spacing-sm);
  }

  .section-tag.ai-tag {
    color: var(--color-ai);
  }

  .section-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  /* Benefits Section (Req 2.3) */
  .benefits-section {
    background-color: var(--color-bg-white);
  }

  .benefit-card {
    background-color: var(--color-bg-light);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--spacing-xl);
    text-align: center;
    transition: transform 0.2s ease-in-out;
  }

  .benefit-card:hover {
    transform: translateY(-2px);
  }

  .benefit-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--spacing-md);
  }

  .benefit-title {
    font-size: 1.2rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-dark);
  }

  .benefit-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Services details stack styling */
  .services-detail-section {
    background-color: #f9fafb;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .services-stack {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxl);
  }

  .service-detail-item {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: var(--spacing-xxl);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
  }

  .service-detail-item.ai-item {
    border-color: var(--color-ai);
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.08);
  }

  .service-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xxl);
  }

  @media (min-width: 1025px) {
    .service-detail-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .detail-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary-light);
    line-height: 1;
    display: block;
    margin-bottom: var(--spacing-xs);
  }

  .ai-item .detail-number {
    color: var(--color-ai-light);
  }

  .detail-lead {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
  }

  /* AI feature highlights box (Req 2.2) */
  .ai-addon-box {
    background-color: var(--color-ai-light);
    border-left: 4px solid var(--color-ai);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: 0 8px 8px 0;
    margin-bottom: var(--spacing-lg);
  }

  .ai-addon-box h4 {
    color: var(--color-ai-hover);
    margin-top: 0;
    margin-bottom: var(--spacing-xs);
    font-size: 1.05rem;
  }

  .ai-addon-box p {
    color: var(--color-text-dark);
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Manual updates notice box (Req 2.2) */
  .manual-pricing-notice {
    background-color: var(--color-primary-light);
    border-left: 4px solid var(--color-primary);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: 0 8px 8px 0;
    margin-bottom: var(--spacing-lg);
  }

  .manual-pricing-notice h4 {
    color: var(--color-primary-hover);
    margin-top: 0;
    margin-bottom: var(--spacing-xs);
    font-size: 1.05rem;
  }

  .manual-pricing-notice p {
    color: var(--color-text-dark);
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .manual-pricing-notice a {
    color: var(--color-primary-hover);
    font-weight: 700;
    text-decoration: underline;
    display: inline;
    min-height: auto;
    min-width: auto;
  }

  .markdown-body {
    margin-top: var(--spacing-lg);
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .markdown-body h2 {
    font-size: 1.25rem;
    margin-top: var(--spacing-lg);
  }

  .markdown-body h3 {
    font-size: 1.05rem;
  }

  /* Sidebars specs listing */
  .service-detail-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .sidebar-box {
    background-color: var(--color-bg-light);
    border: 1px solid var(--color-border);
    padding: var(--spacing-lg);
    border-radius: 12px;
  }

  .sidebar-box h3 {
    font-size: 1.1rem;
    margin-top: 0;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-dark);
  }

  .feature-checklist {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .feature-checklist li {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .feature-checklist svg {
    color: var(--color-success);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ai-item .feature-checklist svg {
    color: var(--color-ai);
  }

  .audience-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .audience-list li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Technical Specs Table - Req 2.4, 2.5 */
  .tech-specs-section {
    background-color: var(--color-bg-white);
  }

  .table-wrapper {
    overflow-x: auto; /* Prevent horizontal scrolling on mobile - Req 7.7 */
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
    margin-bottom: var(--spacing-xl);
  }

  .specs-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.9rem;
  }

  .specs-table th, .specs-table td {
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
  }

  .specs-table thead th {
    background-color: var(--color-bg-light);
    color: var(--color-text-dark);
    font-weight: 700;
  }

  .specs-table tbody th {
    font-weight: 600;
    background-color: rgba(0, 0, 0, 0.01);
    color: var(--color-text-dark);
    min-width: 160px;
  }

  .specs-table td {
    color: var(--color-text-muted);
  }

  .specs-table tr:last-child th, .specs-table tr:last-child td {
    border-bottom: none;
  }

  .supported {
    color: var(--color-success) !important;
    font-weight: 600;
  }

  .unsupported {
    color: var(--color-text-muted) !important;
    opacity: 0.6;
  }

  /* Specs Pending Alert - Req 2.5 */
  .specs-pending-alert {
    background-color: var(--color-primary-light);
    color: var(--color-primary-hover);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: 8px;
    border: 1.5px solid var(--color-primary);
  }

  .pending-text {
    margin-bottom: 0;
    font-size: 0.875rem;
    color: var(--color-primary-hover);
    line-height: 1.5;
  }
</style>
