---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaSection from '../components/CtaSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Web Hosting Services for Small Businesses"
  description="Explore our web hosting services, including basic hosting, AI-enabled hosting that lets you update your website by talking to it in plain English, and custom solutions for small local businesses."
>
  <PageHeader
    heading="Our Hosting Services"
    subheading='From basic web hosting to AI-enabled hosting that lets you update your website by "talking" to it, we have the right plan for your small business or personal site.'
  />

  <section class="section" aria-labelledby="services-list-heading">
    <div class="container">
      <h2 id="services-list-heading" class="sr-only">Available Services</h2>
      <div class="services-grid">
        {services.map(service => (
          <div class="service-detail">
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              icon={service.data.icon}
              features={service.data.features}
              featured={service.data.featured}
            />
            {service.data.body && (
              <div class="service-body">
                <p>{service.data.body}</p>
              </div>
            )}
            {service.data.targetAudience.length > 0 && (
              <div class="service-audience">
                <h3>Ideal For</h3>
                <ul>
                  {service.data.targetAudience.map(audience => (
                    <li>{audience}</li>
                  ))}
                </ul>
              </div>
            )}
            {service.data.featured && (
              <div class="ai-how-it-works">
                <h3>How "Talking" to Your Website Works</h3>
                <ol class="ai-steps">
                  <li>Tell your website what you want to change in plain English</li>
                  <li>Your dedicated AI assistant processes the request and makes the updates</li>
                  <li>Review the changes and approve with one click before they go live</li>
                </ol>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaSection
    heading="Find the Right Plan for You"
    body="Compare our hosting plans and find the perfect fit for your business."
    primaryText="View Pricing"
    primaryLink="/pricing/"
    secondaryText="Ask a Question"
    secondaryLink="/contact/"
  />
</BaseLayout>

<style>
  .services-grid {
    display: grid;
    gap: var(--spacing-10);
  }

  .service-detail {
    display: grid;
    gap: var(--spacing-6);
  }

  .service-body p {
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .service-audience h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-3);
  }

  .service-audience ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .service-audience li {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    padding: var(--spacing-1) var(--spacing-3);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  /* AI "how it works" callout, shown only on the featured service */
  .ai-how-it-works {
    padding: var(--spacing-6);
    background-color: var(--color-primary-light);
    border-radius: var(--radius-lg);
  }

  .ai-how-it-works h3 {
    font-size: var(--font-size-lg);
    color: var(--color-primary);
    margin-bottom: var(--spacing-3);
  }

  .ai-steps {
    padding-left: var(--spacing-5);
  }

  .ai-steps li {
    list-style: decimal;
    margin-bottom: var(--spacing-2);
    padding-left: var(--spacing-2);
    line-height: 1.6;
  }
</style>
