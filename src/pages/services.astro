---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Web Hosting Services for Small Businesses"
  description="Explore our web hosting services including basic hosting, AI-enabled website management, and custom solutions for small local businesses."
>
  <section class="section page-header">
    <div class="container">
      <h1>Our Hosting Services</h1>
      <p class="page-intro">
        From basic web hosting to AI-powered website management, we have the right plan for your small business or personal site.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="services-list-heading">
    <div class="container">
      <h2 id="services-list-heading" class="sr-only">Available Services</h2>
      <div class="services-grid">
        {services.map(service => (
          <div class="service-detail">
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              icon={service.data.icon}
              features={service.data.features}
            />
            {service.data.body && (
              <div class="service-body">
                <p>{service.data.body}</p>
              </div>
            )}
            {service.data.targetAudience.length > 0 && (
              <div class="service-audience">
                <h3>Ideal For</h3>
                <ul>
                  {service.data.targetAudience.map(audience => (
                    <li>{audience}</li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section ai-highlight" aria-labelledby="ai-heading">
    <div class="container">
      <h2 id="ai-heading">AI-Powered Website Management</h2>
      <div class="ai-content">
        <div class="ai-description">
          <p>
            Our revolutionary AI feature lets small business owners manage their website by simply talking to it in plain English. No coding, no complicated dashboards — just tell your website what you want and it happens.
          </p>
          <h3>How It Works</h3>
          <ol class="ai-steps">
            <li>Tell your website what you want to change in plain English</li>
            <li>The AI processes your request and makes the updates</li>
            <li>Review the changes and approve with one click</li>
          </ol>
          <p>
            The AI feature is available as a fixed monthly add-on to any hosting plan. If you prefer to make manual updates to your site, <a href="/contact/">contact us</a> for pricing as costs vary based on your website type.
          </p>
        </div>
        <div class="ai-benefits">
          <h3>Benefits for Small Businesses</h3>
          <ul>
            <li>Save time — no need to learn technical tools</li>
            <li>Save money — no developer needed for simple changes</li>
            <li>Stay current — update your site anytime, anywhere</li>
            <li>Look professional — AI ensures consistent design</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section" aria-labelledby="services-cta">
    <div class="container cta-inner">
      <h2 id="services-cta">Find the Right Plan for You</h2>
      <p>Compare our hosting plans and find the perfect fit for your business.</p>
      <div class="cta-buttons">
        <a href="/pricing/" class="btn btn-primary">View Pricing</a>
        <a href="/contact/" class="btn btn-secondary">Ask a Question</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-bg-alt);
    padding-bottom: var(--spacing-8);
  }

  .page-intro {
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
    margin-top: var(--spacing-4);
    max-width: 700px;
  }

  .services-grid {
    display: grid;
    gap: var(--spacing-10);
  }

  .service-detail {
    display: grid;
    gap: var(--spacing-6);
  }

  .service-body p {
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .service-audience h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-3);
  }

  .service-audience ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .service-audience li {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    padding: var(--spacing-1) var(--spacing-3);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  .ai-highlight {
    background-color: var(--color-bg-alt);
  }

  .ai-content {
    display: grid;
    gap: var(--spacing-8);
    margin-top: var(--spacing-6);
  }

  @media (min-width: 768px) {
    .ai-content {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ai-description p {
    margin-bottom: var(--spacing-4);
    line-height: 1.7;
  }

  .ai-description a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .ai-description h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-3);
  }

  .ai-steps {
    margin-bottom: var(--spacing-4);
    padding-left: var(--spacing-5);
  }

  .ai-steps li {
    list-style: decimal;
    margin-bottom: var(--spacing-2);
    padding-left: var(--spacing-2);
  }

  .ai-benefits h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-3);
  }

  .ai-benefits ul {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .ai-benefits li {
    padding-left: var(--spacing-5);
    position: relative;
  }

  .ai-benefits li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    font-weight: 700;
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e40af 100%);
    color: var(--color-text-inverse);
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
  }

  .cta-inner h2 {
    color: var(--color-text-inverse);
    margin-bottom: var(--spacing-4);
  }

  .cta-inner p {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-8);
    opacity: 0.95;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-buttons .btn-secondary {
    color: var(--color-text-inverse);
    border-color: var(--color-text-inverse);
  }

  .cta-buttons .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.15);
  }
</style>
